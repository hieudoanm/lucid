{
  "name": "@nothing-server/nothing.tech",
  "version": "0.0.1",
  "private": true,
  "description": "nothing.tech",
  "keywords": [
    "chess",
    "pdfmake"
  ],
  "homepage": "https://github.com/hieudoanm/sandbox#readme",
  "bugs": {
    "url": "https://github.com/hieudoanm/sandbox/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hieudoanm/sandbox.git"
  },
  "license": "GPL-3.0",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "type": "commonjs",
  "main": "./dist/server.js",
  "directories": {
    "example": "examples"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "25.8.1"
  },
  "scripts": {
    "format": "prettier --cache --write .",
    "prelint": "pnpm prisma:generate",
    "lint": "eslint . --fix",
    "prebuild": "rimraf build dist && pnpm prisma:generate",
    "build": "tsc --project tsconfig.build.json",
    "predev": "pnpm prisma:generate",
    "dev": "nodemon",
    "prestart": "pnpm prisma:generate",
    "start": "node ./dist/server.js",
    "prisma:generate": "prisma format && prisma generate",
    "prisma:push": "pnpm prisma:generate && prisma db push",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "7.5.0",
    "graphql": "16.13.1",
    "html-to-pdfmake": "2.5.33",
    "jsdom": "29.0.1",
    "kafkajs": "2.2.4",
    "pdf2html": "4.4.0",
    "pdfmake": "0.3.7",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "public-ip": "8.0.0",
    "puppeteer": "24.40.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/html-to-pdfmake": "2.4.5",
    "@types/node": "25.5.0",
    "@webpack-cli/generators": "3.0.7",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.5.0",
    "rimraf": "6.1.3",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.1",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2"
  }
}
